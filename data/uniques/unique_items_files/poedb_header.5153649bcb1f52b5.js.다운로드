class Zoom {
    init() {
        this.root = document.getElementsByTagName('svg')[0];
        this.root.style.touchAction = 'none';
        this.WIDTH = this.root.viewBox.baseVal.width;
        this.HEIGHT = this.root.viewBox.baseVal.height;

        this.MIN_ZOOM = 0.7;
        this.MAX_ZOOM = 15.0;
        this.ZOOM_FACTOR = 1 / 100;

        this.zoomLevel = 1;

        this.center_x = 0;
        this.center_y = 0;

        this.pointers = {};
        this.lastDist = null;

        this.root.addEventListener('pointerdown', this.onPointerDown.bind(this), {
            passive: true
        });
        this.root.addEventListener('pointermove', this.onPointerMove.bind(this), {
            passive: true
        });
        this.root.addEventListener('pointerup', this.onPointerLeave.bind(this), {
            passive: true
        });
        this.root.addEventListener('pointercancel', this.onPointerLeave.bind(this), {
            passive: true
        });
        this.root.addEventListener('wheel', this.onWheel.bind(this), {
            passive: false
        });
    }

    update() {
        const dx = this.WIDTH / this.zoomLevel;
        const dy = this.HEIGHT / this.zoomLevel;
        const x = this.center_x / this.zoomLevel - dx / 2;
        const y = this.center_y / this.zoomLevel - dy / 2;
        this.root.setAttribute('viewBox', `${x} ${y} ${dx} ${dy}`);
    }

    zoom(pixels) {
        if (pixels === 0) {
            return;
        }

        const newZoomLevel = Math.min(this.MAX_ZOOM, Math.max(this.MIN_ZOOM, this.zoomLevel - pixels * this.ZOOM_FACTOR));
        if (Math.abs(this.zoomLevel - newZoomLevel) < 0.001) {
            return false;
        }

        this.center_x -= this.center_x * (1 - newZoomLevel / this.zoomLevel);
        this.center_y -= this.center_y * (1 - newZoomLevel / this.zoomLevel);
        this.zoomLevel = newZoomLevel;

        this.update();
        return true;
    }

    onPointerDown(event) {
        this.pointers[event.pointerId] = {
            x: event.clientX,
            y: event.clientY
        };
        $('#funcPanel').addClass('unselectable');
        this.statsPanelVisible = $('#statsPanel').is(':visible');
        if (this.statsPanelVisible) {
            $('#statsPanel').collapse('hide');
        }
    }

    onPointerMove(event) {
        if (!this.pointers[event.pointerId]) {
            return;
        }
        const numPointers = Object.keys(this.pointers).length;
        if (numPointers === 1) {
            const lastPosition = this.pointers[event.pointerId];
            if (event.clientX == lastPosition.x && event.clientY == lastPosition.y) {
                return;
            }
            let scale = Math.max(this.WIDTH / window.innerWidth, this.HEIGHT / window.innerHeight);
            this.center_x += (lastPosition.x - event.clientX) * scale;
            this.center_y += (lastPosition.y - event.clientY) * scale;
            this.update();
        } else if (numPointers === 2) {
            const other = Object.keys(this.pointers).find(x => x != event.pointerId);
            const lastPosition = this.pointers[other];

            const dist = Math.hypot(lastPosition.x - event.clientX, lastPosition.y - event.clientY,);
            if (this.lastDist !== null) {
                const pinch = this.lastDist - dist;
                this.zoom(pinch);
            }
            this.lastDist = dist;
        }
        this.pointers[event.pointerId] = {
            x: event.clientX,
            y: event.clientY
        };
    }

    onPointerLeave(event) {
        delete this.pointers[event.pointerId];
        this.lastDist = null;
        $('#funcPanel').removeClass('unselectable');
        if (this.statsPanelVisible) {
            $('#statsPanel').collapse('show');
        }
    }

    onWheel(event) {
        if (event.ctrlKey || event.altKey) {
            return;
        }
        event.preventDefault();
        this.zoom(event.deltaY)
    }
}

