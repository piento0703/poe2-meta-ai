function filterClick(input) {
  input.on('input', function () {
    var value = $(this).val().trim();
    let target = $(this).data('target') ? $($(this).data('target')) : $(this).closest('form').next().children();
    if (value === '') {
      target.each(function () {
        $(this).toggle(true);
      });
    } else {
      var arrays = value.toLowerCase().split(' ');
      target.each(function () {
        var col = $(this).text().toLowerCase();
        if ($(this).data('filters')) {
          col += ' ' + $(this).data('filters').toLowerCase();
        }
        $(this).toggle(arrayIndexOf(arrays, col));
      });
    }
  });

  input.closest('form').find(':reset').click(function (e) {
    input.val('').trigger('input');
  });
}

