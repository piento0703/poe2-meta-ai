function getPageLang() {
  let langLocales = {
    'zh-Hant': 'tw',
    'tw': 'tw',
    'zh-Hans': 'cn',
    'cn': 'cn',
    'fr': 'fr',
    'es': 'sp',
    'sp': 'sp',
    'de': 'de',
    'ko': 'kr',
    'kr': 'kr',
    'ru': 'ru',
    'pt': 'pt',
    'en': 'us',
    'us': 'us',
    'th': 'th',
    'ja': 'jp',
    'jp': 'jp',
  };
  if (lang = langLocales[document.documentElement.lang]) {
    return lang;
  }
  if ($.inArray('/' + document.documentElement.lang + '/', langPaths) != -1) {
    return document.documentElement.lang;
  }
  return getLang(window.location.href);
}

