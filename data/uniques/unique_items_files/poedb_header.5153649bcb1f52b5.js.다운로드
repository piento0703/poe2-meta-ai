function fixAdPlacement() {
  var validWidth = 1140 + 170 * 2;
  var menuTop = $('div.navbar').height() + 10;
  //console.log("menuTop->" + menuTop);

  if ($(window).width() < validWidth) {
    //console.log("init_hide");
    $(".fix").hide();
  } else {
    //console.log("init_show");
    $(".fix").show();
    $(".fix").css({
      position: "fixed",
      top: menuTop.toString() + 'px',
      right: '10px'
    });
  }

  $(window).resize(function () {
    wdth = $(window).width();
    if (wdth > validWidth) {
      //console.log("run_show");
      $(".fix").show();
      $(".fix").css({
        position: "fixed",
        top: menuTop.toString() + 'px',
        right: '10px'
      });
    } else {
      //console.log("run_hide");
      $(".fix").hide();
    }
  });

  var lastScrollTop = 0;
  $(window).scroll(function (event) {
    var st = $(this).scrollTop();
    var current = $(document).scrollTop();
    if (st > lastScrollTop) {
      //console.log("down_current->" + current);
      if (current > menuTop) {
        $(".fix").css({
          position: "fixed",
          top: '10px',
          right: '10px'
        });
      }
    } else {
      //console.log("up_current->" + current);
      if (current < menuTop) {
        $(".fix").css({
          position: "fixed",
          top: menuTop.toString() + 'px',
          right: '10px'
        });
      }
    }
    lastScrollTop = st;
  });
}

